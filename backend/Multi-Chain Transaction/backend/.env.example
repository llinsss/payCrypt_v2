# Monitoring
MONITOR_INTERVAL=30000
STUCK_TX_THRESHOLD_MS=1800000

# Alert Webhooks
ALERT_WEBHOOK_SLACK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
ALERT_EMAIL_FROM=alerts@yourapp.com
ALERT_EMAIL_TO=ops@yourapp.com
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass

# Redis
REDIS_URL=redis://localhost:6379

# RPC Endpoints
STARKNET_RPC_URL=https://starknet-mainnet.infura.io/v3/YOUR_KEY
BASE_RPC_URL=https://mainnet.base.org
FLOW_ACCESS_NODE=https://rest-mainnet.onflow.org
LISK_RPC_URL=https://rpc.api.lisk.com
U2U_RPC_URL=https://rpc-mainnet.uniultra.xyz

# Gas Alert Thresholds (in Gwei)
GAS_ALERT_THRESHOLD_BASE=50
GAS_ALERT_THRESHOLD_LISK=50
GAS_ALERT_THRESHOLD_U2U=50

# Prometheus
METRICS_PORT=9090
