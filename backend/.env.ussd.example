# USSD Configuration

# USSD Provider (africastalking or twilio)
USSD_PROVIDER=africastalking

# Africa's Talking Credentials
AFRICASTALKING_API_KEY=your_api_key_here
AFRICASTALKING_USERNAME=sandbox

# Twilio Credentials (alternative)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token

# USSD Service Code
USSD_SERVICE_CODE=*123*456#

# Security
USSD_GATEWAY_IPS=197.232.0.0/16,41.90.0.0/16
USSD_MAX_DAILY_TRANSACTIONS=10
USSD_MAX_TRANSACTION_AMOUNT=50000
