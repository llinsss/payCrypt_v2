# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Cache ─────────────────────────────────────────────────────────────────────
# Balance cache TTL in seconds (default: 60)
BALANCE_CACHE_TTL=60

# How many top-active users to pre-warm on startup / scheduled run (default: 1000)
CACHE_WARMING_LIMIT=1000
