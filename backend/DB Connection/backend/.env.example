# Application
NODE_ENV=development
PORT=3000

# Database connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app_db
DB_USER=postgres
DB_PASSWORD=

# Test database
DB_TEST_NAME=app_db_test

# Connection pool tuning
# min: keep at least this many idle connections alive
DB_POOL_MIN=2
# max: never exceed this many simultaneous connections
DB_POOL_MAX=10
# ms to wait for a free connection before throwing
DB_POOL_ACQUIRE_TIMEOUT=30000
# ms an idle connection is kept before being released
DB_POOL_IDLE_TIMEOUT=30000

# Load test
LOAD_TEST_CONCURRENCY=20
LOAD_TEST_ITERATIONS=100
